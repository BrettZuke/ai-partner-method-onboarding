# ── Typeform ─────────────────────────────────────────────────────────────────
# Get this from: typeform.com → Account Settings → Personal tokens
TYPEFORM_API_KEY=

# ── Notion ────────────────────────────────────────────────────────────────────
# 1. Go to notion.so/my-integrations → New integration → copy the secret
NOTION_API_KEY=
# 2. Create a "Client Workspaces" page in Notion
# 3. Share it with your integration (Share → Invite → your integration name)
# 4. Copy the page ID from the URL (32-char string after the last /)
NOTION_PARENT_PAGE_ID=
